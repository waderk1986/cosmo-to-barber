---
import BeamsHero from '../components/BeamsHero.tsx'
import { GetStartedButton } from '../components/ui/get-started-button'
import '../styles/global.css'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
      Cosmetology to Barbering — Summer 2026 | Technical College of the Rockies
    </title>
    <meta
      name="description"
      content="Two-week crossover course for licensed cosmetologists seeking Colorado barbering licensure. June 15–26, 2026. $650. Apply now."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      html {
        font-size: 16px;
      }
      body {
        font-family: 'DM Sans', sans-serif;
        background: #ffffff;
        color: #1a1a1a;
        -webkit-font-smoothing: antialiased;
      }
      a {
        color: #008080;
      }
      p {
        line-height: 1.75;
        color: #4a4a4a;
      }
      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }
      :focus-visible {
        outline: 3px solid #008080;
        outline-offset: 3px;
      }
      @media (prefers-reduced-motion: reduce) {
        * {
          animation-duration: 0.01ms !important;
          transition-duration: 0.01ms !important;
        }
      }

      /* ── SECTIONS ── */
      .section {
        padding: 6rem 0;
      }
      .section-alt {
        background: #f8f8f8;
      }
      .container {
        max-width: 64rem;
        margin: 0 auto;
        padding: 0 1.5rem;
      }
      .section-label {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: #008080;
        margin-bottom: 1rem;
      }
      .section-title {
        font-family: 'Bebas Neue', sans-serif;
        font-size: clamp(2.5rem, 6vw, 4rem);
        line-height: 0.92;
        letter-spacing: 0.02em;
        color: #1a1a1a;
        margin-bottom: 1.5rem;
      }
      .section-title span {
        color: #cccccc;
      }

      /* ── CARDS ── */
      .card-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
        margin-top: 3rem;
      }
      .card {
        border: 1.5px solid rgba(0, 128, 128, 0.15);
        border-radius: 1rem;
        padding: 2.5rem;
        background: #ffffff;
        position: relative;
        overflow: hidden;
        transition:
          border-color 0.2s,
          box-shadow 0.2s;
      }
      .card:hover {
        border-color: rgba(0, 128, 128, 0.3);
        box-shadow: 0 8px 32px rgba(0, 128, 128, 0.06);
      }
      .card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(
          90deg,
          transparent,
          rgba(0, 128, 128, 0.4),
          transparent
        );
      }
      .card-tag {
        display: inline-block;
        padding: 0.2rem 0.75rem;
        margin-bottom: 1.5rem;
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        background: rgba(0, 128, 128, 0.08);
        color: #008080;
        border-radius: 9999px;
      }
      .card-title {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 3rem;
        letter-spacing: 0.02em;
        margin-bottom: 1rem;
      }
      .card-title.teal {
        color: #008080;
      }
      .card-title.dark {
        color: #1a1a1a;
      }
      .card-body {
        font-size: 0.9rem;
        line-height: 1.7;
        color: #4a4a4a;
        margin-bottom: 2rem;
      }
      .card-rows {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
      }
      .card-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.85rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        color: #6a6a6a;
      }
      .card-row:last-child {
        border-bottom: none;
        padding-bottom: 0;
      }
      .card-row strong {
        color: #1a1a1a;
        font-weight: 600;
      }

      /* ── WHY THIS SUMMER ── */
      .reasons {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 3rem;
        margin-top: 5rem;
      }
      .reason-num {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 4rem;
        color: rgba(0, 0, 0, 0.05);
        line-height: 1;
      }
      .reason h3 {
        font-size: 1.1rem;
        font-weight: 600;
        color: #1a1a1a;
        margin: 1rem 0 0.75rem;
      }
      .reason p {
        font-size: 0.9rem;
        line-height: 1.7;
      }

      /* ── HOW TO APPLY ── */
      .steps {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
        margin-top: 3rem;
      }
      .step {
        border: 1.5px solid rgba(0, 0, 0, 0.06);
        border-radius: 1rem;
        padding: 2rem;
        position: relative;
        overflow: hidden;
        transition:
          border-color 0.2s,
          box-shadow 0.2s;
      }
      .step:hover {
        border-color: rgba(0, 128, 128, 0.25);
        box-shadow: 0 8px 24px rgba(0, 128, 128, 0.05);
      }
      .step-num {
        position: absolute;
        top: 1.25rem;
        right: 1.5rem;
        font-family: 'Bebas Neue', sans-serif;
        font-size: 3rem;
        color: rgba(0, 0, 0, 0.04);
        line-height: 1;
      }
      .step-icon {
        width: 2.5rem;
        height: 2.5rem;
        border-radius: 0.75rem;
        background: rgba(0, 128, 128, 0.08);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.25rem;
        color: #008080;
      }
      .step h3 {
        font-size: 1rem;
        font-weight: 600;
        color: #1a1a1a;
        margin-bottom: 0.5rem;
      }
      .step p {
        font-size: 0.85rem;
        line-height: 1.65;
      }
      .apply-cta {
        margin-top: 4rem;
        border: 1.5px solid rgba(0, 128, 128, 0.2);
        border-radius: 1rem;
        padding: 3rem;
        background: rgba(0, 128, 128, 0.03);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 2rem;
        flex-wrap: wrap;
      }
      .apply-cta h3 {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 2.5rem;
        letter-spacing: 0.02em;
        color: #1a1a1a;
        margin-bottom: 0.5rem;
      }
      .apply-cta p {
        font-size: 0.9rem;
        max-width: 28rem;
      }

      /* ── COST ── */
      .cost-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
      }
      .cost-card {
        border: 1.5px solid rgba(0, 0, 0, 0.08);
        border-radius: 1rem;
        padding: 2.5rem;
        background: #ffffff;
        box-shadow: 0 2px 16px rgba(0, 0, 0, 0.04);
      }
      .cost-label {
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: #aaaaaa;
        padding-bottom: 1.5rem;
        margin-bottom: 1.5rem;
        border-bottom: 1px solid rgba(0, 0, 0, 0.06);
      }
      .cost-amount {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 6rem;
        color: #1a1a1a;
        line-height: 1;
        margin-bottom: 0.25rem;
      }
      .cost-sub {
        font-size: 0.75rem;
        color: #aaaaaa;
        margin-bottom: 2rem;
      }
      .cost-rows {
        padding-top: 1.5rem;
        margin-bottom: 2rem;
        border-top: 1px solid rgba(0, 0, 0, 0.06);
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
      }
      .cost-row {
        display: flex;
        justify-content: space-between;
        font-size: 0.85rem;
        color: #6a6a6a;
      }
      .cost-row em {
        font-style: italic;
      }

      /* ── BUTTONS ── */
      .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.9rem 2rem;
        background: #008080;
        color: #ffffff;
        font-weight: 700;
        font-size: 0.95rem;
        border-radius: 9999px;
        text-decoration: none;
        transition:
          background 0.2s,
          transform 0.15s;
      }
      .btn-primary:hover {
        background: #006b6b;
        transform: translateY(-1px);
      }
      .btn-full {
        width: 100%;
        justify-content: space-between;
        border-radius: 0.75rem;
      }

      /* ── FOOTER ── */
      footer {
        padding: 4rem 0;
        background: #f8f8f8;
        border-top: 1px solid rgba(0, 0, 0, 0.06);
        text-align: center;
      }
      footer p {
        font-size: 0.85rem;
        color: #888888;
        margin-bottom: 0.25rem;
      }
      footer a {
        color: #008080;
        text-decoration: none;
      }
      footer a:hover {
        text-decoration: underline;
      }
      .footer-name {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 1.75rem;
        letter-spacing: 0.04em;
        color: #1a1a1a;
        margin-bottom: 0.5rem;
      }

      /* ── RESPONSIVE ── */
      @media (max-width: 768px) {
        .card-grid,
        .reasons,
        .steps,
        .cost-grid {
          grid-template-columns: 1fr;
        }
        .apply-cta {
          flex-direction: column;
        }
        .section {
          padding: 4rem 0;
        }
      }
    </style>
  </head>
  <link rel="icon" type="image/png" href="/images/black-logo.png" />
  <body>
    <a href="#main" class="sr-only">Skip to main content</a>

    <main id="main">
      <!-- HERO -->
      <BeamsHero client:only="react" />

      <!-- PROGRAM DETAILS -->
      <section class="section" aria-labelledby="program-heading">
        <div class="container">
          <p class="section-label">About This Course</p>
          <h2 id="program-heading" class="section-title">
            Dual licensure in<br /><span>two weeks</span>
          </h2>
          <p style="max-width:40rem; font-size:1.05rem;">
            Designed for currently licensed cosmetologists, this concentrated
            crossover covers the barbering-specific skills and knowledge
            required to sit for the Colorado DORA Barbering License exam.
          </p>
          <div class="card-grid">
            <div class="card">
              <span class="card-tag">Your Foundation</span>
              <h3 class="card-title teal">Cosmetology</h3>
              <p class="card-body">
                You already have the license, the training, and the client
                skills. This course builds on everything you know with no
                starting over, and no redundancy.
              </p>
              <div class="card-rows">
                <div class="card-row">
                  <span>Prerequisite</span><strong
                    >Active CO Cosmetology License</strong
                  >
                </div>
                <div class="card-row">
                  <span>Schedule</span><strong>Mon – Fri, 8 AM – 4 PM</strong>
                </div>
                <div class="card-row">
                  <span>Format</span><strong>Full-day, in-seat</strong>
                </div>
              </div>
            </div>
            <div class="card">
              <span class="card-tag">What You Gain</span>
              <h3 class="card-title dark">Barbering</h3>
              <p class="card-body">
                Straight razor technique, barbering-specific cuts, and the
                knowledge to pass the DORA exam. Dual licensure opens doors to
                barber shops, full-service salons, and independent suites.
              </p>
              <div class="card-rows">
                <div class="card-row">
                  <span>Credential</span><strong
                    >CO DORA Barbering License</strong
                  >
                </div>
                <div class="card-row">
                  <span>Duration</span><strong>2 weeks / 3 credits</strong>
                </div>
                <div class="card-row">
                  <span>Instructor</span><strong>Sergio Antillon</strong>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- WHY THIS SUMMER -->
      <section class="section section-alt" aria-labelledby="why-heading">
        <div class="container">
          <p class="section-label">Why This Summer</p>
          <h2 id="why-heading" class="section-title">
            Three reasons to<br /><span>start now</span>
          </h2>
          <div class="reasons">
            <div class="reason">
              <div class="reason-num" aria-hidden="true">01</div>
              <h3>Career-ready in two weeks</h3>
              <p>
                No semester-long commitment. Full-day, in-seat instruction from
                June 15 through June 26. Then you sit for the exam. Most
                graduates are dual-licensed before July.
              </p>
            </div>
            <div class="reason">
              <div class="reason-num" aria-hidden="true">02</div>
              <h3>$650 - No hidden costs</h3>
              <p>
                The course fee covers tuition and instruction. You need a Level
                3 straight razor (~$22 at saloncentric.com) and the required
                textbook. That's it.
              </p>
            </div>
            <div class="reason">
              <div class="reason-num" aria-hidden="true">03</div>
              <h3>Small cohort, real attention</h3>
              <p>
                This isn't a lecture hall. It's a concentrated, hands-on program
                led by Sergio Antillon. You get direct instruction, real
                feedback, and straight razor time every single day.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- HOW TO APPLY -->
      <section class="section" aria-labelledby="apply-heading">
        <div class="container">
          <p class="section-label">How to Apply</p>
          <h2 id="apply-heading" class="section-title">
            Three documents.<br /><span>That's it.</span>
          </h2>
          <p style="max-width:40rem; font-size:1.05rem;">
            Upload all three as part of your application. Files may be photos or
            scans — legibility required.
          </p>
          <div class="steps">
            <div class="step">
              <span class="step-num" aria-hidden="true">01</span>
              <div class="step-icon">
                <svg
                  width="20"
                  height="20"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15 9h3.75M15 12h3.75M15 15h3.75M4.5 19.5h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15A2.25 2.25 0 002.25 6.75v10.5A2.25 2.25 0 004.5 19.5zm6-10.125a1.875 1.875 0 11-3.75 0 1.875 1.875 0 013.75 0zm1.294 6.336a6.721 6.721 0 01-3.17.789 6.721 6.721 0 01-3.168-.789 3.376 3.376 0 016.338 0z"
                  ></path></svg
                >
              </div>
              <h3>Active Cosmetology License</h3>
              <p>
                Current, active Colorado Cosmetology License (or equivalent
                out-of-state). Must be valid at enrollment.
              </p>
            </div>
            <div class="step">
              <span class="step-num" aria-hidden="true">02</span>
              <div class="step-icon">
                <svg
                  width="20"
                  height="20"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15A2.25 2.25 0 002.25 6.75v10.5A2.25 2.25 0 004.5 19.5z"
                  ></path></svg
                >
              </div>
              <h3>Government-Issued Photo ID</h3>
              <p>
                Valid driver's license, passport, or other government-issued
                photo identification.
              </p>
            </div>
            <div class="step">
              <span class="step-num" aria-hidden="true">03</span>
              <div class="step-icon">
                <svg
                  width="20"
                  height="20"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.62 48.62 0 0112 20.904a48.62 48.62 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.636 50.636 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"
                  ></path></svg
                >
              </div>
              <h3>High School Diploma or GED</h3>
              <p>A copy of your high school diploma or GED certificate.</p>
            </div>
          </div>
          <div class="apply-cta">
            <div>
              <h3>Ready to go?</h3>
              <p>
                The application takes about 10 minutes. Have your three
                documents ready to upload.
              </p>
            </div>
            <GetStartedButton
              client:visible
              href="https://tcr.populiweb.com/router/admissions/onlineapplications/index?application_form=14"
            >
              Start Your Application
            </GetStartedButton>
          </div>
        </div>
      </section>

      <!-- COST -->
      <section class="section section-alt" aria-labelledby="cost-heading">
        <div class="container">
          <div class="cost-grid">
            <div>
              <p class="section-label">Tuition &amp; Fees</p>
              <h2 id="cost-heading" class="section-title">Course cost</h2>
              <p style="margin-bottom:1rem;">
                The course fee covers tuition and instruction for the two-week
                program. The required textbook and straight razor are not
                included.
              </p>
              <p>
                Full payment of $650 is due prior to the start date. This
                short-term course does not qualify for Federal Financial Aid.
              </p>
            </div>
            <div class="cost-card">
              <p class="cost-label">Cosmetology to Barbering — June 2026</p>
              <p class="cost-amount">$650</p>
              <p class="cost-sub">Course fee only</p>
              <div class="cost-rows">
                <div class="cost-row">
                  <span>Required textbook</span><em>Not included</em>
                </div>
                <div class="cost-row">
                  <span>Level 3 straight razor</span><em
                    >~$22 at saloncentric.com</em
                  >
                </div>
              </div>
              <GetStartedButton
                client:visible
                href="https://tcr.populiweb.com/router/admissions/onlineapplications/index?application_form=14"
                className="!w-full !justify-between !rounded-xl"
              >
                Apply for this course
              </GetStartedButton>
            </div>
          </div>
        </div>
      </section>
    </main>

    <!-- FOOTER -->
    <footer>
      <div class="container">
        <p class="footer-name">Technical College of the Rockies</p>
        <p>Delta, Colorado</p>
        <p><a href="tel:9708747671">(970) 874-7671</a></p>
        <p style="margin-top:1.5rem;">
          <a href="https://tcr.edu" target="_blank" rel="noopener noreferrer"
            >tcr.edu ↗</a
          >
        </p>
      </div>
    </footer>
  </body>
</html>
